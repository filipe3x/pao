# Server
# :3050 é o porto reservado para pao neste VPS (curvsync usa :3033, sleep :3001).
PORT=3050
NODE_ENV=development

# SQLite
DB_PATH=./data/pao.db

# Admin lock — password única para destrancar a edição dos defaults globais.
# Gerar com:  node -e "console.log(require('crypto').randomBytes(24).toString('base64url'))"
ADMIN_PASSWORD=change-me-please

# Segredo para assinar a cookie/token de sessão admin (>= 16 chars).
# Gerar com:  node -e "console.log(require('crypto').randomBytes(32).toString('base64url'))"
ADMIN_SESSION_SECRET=change-me-with-a-long-random-string
