#!/bin/sh
# Backup diário do SQLite via VACUUM INTO (snapshot consistente).
# Copiar para /etc/cron.daily/pao-backup e dar +x.
set -e

DB=/var/www/pao/data/pao.db
DEST=/var/www/pao/data/backups
TS=$(date +%F)
RETAIN_DAYS=30

if [ ! -f "$DB" ]; then
    echo "[pao-backup] $DB não existe, skip." >&2
    exit 0
fi

install -d -o ember -g http-web -m 0750 "$DEST"
sudo -u ember sqlite3 "$DB" "VACUUM INTO '$DEST/pao-$TS.db'"

# Retenção
find "$DEST" -name 'pao-*.db' -mtime "+$RETAIN_DAYS" -delete
