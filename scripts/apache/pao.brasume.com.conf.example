# =============================================================================
# Apache2 vhost — pao.brasume.com
#
# Mesmo VPS do curvsync / words / sleep / embers. Dois blocos:
#   *:80   → permanent redirect to HTTPS
#   *:443  → SPA (DocumentRoot client/dist) + reverse proxy /api → :3050
#
# Node corre como ember:http-web na porta 3050 (ver deploy/systemd/pao.service).
# Apache serve directamente o build; Node trata só da API e da BD SQLite.
#
# Install:
#   sudo a2enmod proxy proxy_http rewrite headers ssl deflate mime
#   sudo cp /var/www/pao/scripts/apache/pao.brasume.com.conf.example \
#           /etc/apache2/sites-available/pao.brasume.com.conf
#   sudo a2ensite pao.brasume.com.conf
#   sudo certbot --apache -d pao.brasume.com           # popula o bloco SSL
#   sudo apache2ctl configtest && sudo systemctl reload apache2
# =============================================================================

<VirtualHost *:80>
  ServerName pao.brasume.com

  RewriteEngine On
  RewriteCond %{SERVER_NAME} =pao.brasume.com
  RewriteRule ^ https://%{SERVER_NAME}%{REQUEST_URI} [END,NE,R=permanent]

  # Se ainda não emitiste o cert, comenta as 3 linhas acima até `certbot --apache` correr.
</VirtualHost>

<IfModule mod_ssl.c>
<VirtualHost *:443>
  ServerName pao.brasume.com

  # SSL (configurado pelo Certbot)
  SSLCertificateFile    /etc/letsencrypt/live/pao.brasume.com/fullchain.pem
  SSLCertificateKeyFile /etc/letsencrypt/live/pao.brasume.com/privkey.pem
  Include /etc/letsencrypt/options-ssl-apache.conf

  DocumentRoot /var/www/pao/client/dist

  # MIME types correctos para módulos ES (Vite output)
  <IfModule mime_module>
    AddType application/javascript .js .mjs
    AddType text/css .css
    AddType application/json .json
    AddType application/manifest+json .webmanifest
  </IfModule>

  <Directory /var/www/pao/client/dist>
    Options -Indexes +FollowSymLinks
    AllowOverride None
    Require all granted

    RewriteEngine On
    RewriteBase /

    # NÃO reescrever ficheiros que existem (JS, CSS, ícones, sw.js, etc.)
    RewriteCond %{REQUEST_FILENAME} -f [OR]
    RewriteCond %{REQUEST_FILENAME} -d
    RewriteRule ^ - [L]

    # SPA fallback — qualquer rota client-side devolve index.html
    RewriteRule ^ index.html [L]
  </Directory>

  # === Cache: assets com hash imutáveis; index/sw/manifest sem cache ===
  <LocationMatch "^/assets/">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </LocationMatch>
  <FilesMatch "(^index\.html$|sw\.js$|\.webmanifest$)">
    Header set Cache-Control "no-cache"
  </FilesMatch>

  # === Compressão (ficheiros não-pré-comprimidos) ===
  <IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE \
      text/html text/plain text/css text/xml \
      application/javascript application/json \
      application/xml image/svg+xml font/woff2 \
      application/manifest+json
  </IfModule>

  # === API → Node (porta 3050) ===
  ProxyPreserveHost On
  RequestHeader set X-Forwarded-Proto "https"
  ProxyPass        /api  http://127.0.0.1:3050/api  retry=0
  ProxyPassReverse /api  http://127.0.0.1:3050/api
  ProxyPass        /healthz  http://127.0.0.1:3050/healthz  retry=0
  ProxyPassReverse /healthz  http://127.0.0.1:3050/healthz

  # === Headers de segurança ===
  Header always set Strict-Transport-Security "max-age=63072000; includeSubDomains"
  Header always set X-Content-Type-Options "nosniff"
  Header always set Referrer-Policy "strict-origin-when-cross-origin"

  ErrorLog  ${APACHE_LOG_DIR}/pao_error.log
  CustomLog ${APACHE_LOG_DIR}/pao_access.log combined
</VirtualHost>
</IfModule>
